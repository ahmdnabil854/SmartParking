@using SmartParking.Models
@model IEnumerable<Booking>

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - SmartParking</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', sans-serif; background: #0f0f1a; color: #fff; display: flex; min-height: 100vh; }

        /* Sidebar */
        .sidebar { width: 220px; background: #1a1a2e; padding: 24px 16px; display: flex; flex-direction: column; gap: 4px; flex-shrink: 0; }
        .sidebar-logo { color: #e8f5a3; font-size: 16px; font-weight: 700; padding: 8px 12px; margin-bottom: 20px; }
        .sidebar a { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 10px; color: #9FE1CB; text-decoration: none; font-size: 14px; transition: all 0.2s; }
        .sidebar a:hover, .sidebar a.active { background: #0f0f1a; color: #e8f5a3; }
        .sidebar-footer { margin-top: auto; }
        .sidebar-footer a { color: #D85A30 !important; }

        /* Main */
        .main { flex: 1; padding: 28px; overflow-y: auto; }
        .page-title { font-size: 20px; font-weight: 600; color: #e8f5a3; margin-bottom: 24px; }

        /* Stats */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 28px; }
        .stat-card { background: #1a1a2e; border-radius: 14px; padding: 18px; border: 1px solid #2a2a3e; }
        .stat-card .stat-icon { font-size: 24px; margin-bottom: 10px; }
        .stat-card .stat-num { font-size: 28px; font-weight: 700; }
        .stat-card .stat-num.green { color: #1D9E75; }
        .stat-card .stat-num.red { color: #D85A30; }
        .stat-card .stat-num.amber { color: #BA7517; }
        .stat-card .stat-num.blue { color: #5469d4; }
        .stat-card .stat-num.white { color: #fff; }
        .stat-card .stat-label { font-size: 12px; color: #888; margin-top: 4px; }

        /* Slots */
        .section-title { font-size: 14px; font-weight: 600; color: #9FE1CB; margin-bottom: 14px; text-transform: uppercase; letter-spacing: 0.5px; }
        .slots-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
        .slot-pill { padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; border: 1.5px solid transparent; }
        .slot-pill.available { background: rgba(29,158,117,0.15); border-color: #1D9E75; color: #1D9E75; }
        .slot-pill.occupied { background: rgba(216,90,48,0.15); border-color: #D85A30; color: #D85A30; }
        .slot-pill.reserved { background: rgba(186,117,23,0.15); border-color: #BA7517; color: #BA7517; }

        /* Table */
        .table-wrapper { background: #1a1a2e; border-radius: 14px; overflow: hidden; border: 1px solid #2a2a3e; }
        .table-header { padding: 16px 20px; border-bottom: 1px solid #2a2a3e; display: flex; justify-content: space-between; align-items: center; }
        .table-header h3 { font-size: 15px; font-weight: 600; color: #e8f5a3; }
        table { width: 100%; border-collapse: collapse; }
        th { padding: 12px 16px; text-align: left; font-size: 11px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #2a2a3e; }
        td { padding: 14px 16px; font-size: 13px; color: #ccc; border-bottom: 1px solid #1f1f30; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #1f1f30; }

        .badge { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge.active { background: rgba(29,158,117,0.15); color: #1D9E75; }
        .badge.cancelled { background: rgba(216,90,48,0.15); color: #D85A30; }
        .badge.completed { background: rgba(84,105,212,0.15); color: #5469d4; }

        .action-btn { padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer; border: none; transition: all 0.2s; }
        .action-btn.cancel { background: rgba(216,90,48,0.15); color: #D85A30; border: 1px solid #D85A30; }
        .action-btn.cancel:hover { background: #D85A30; color: #fff; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-logo">🅿 SmartParking</div>
    <a href="/Admin" class="active">📊 Dashboard</a>
    <a href="/Parking">🚗 Parking View</a>
    <div class="sidebar-footer">
        <a href="/Admin/Logout">🚪 Logout</a>
    </div>
</div>

<div class="main">
    <div class="page-title">Dashboard</div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">🅿️</div>
            <div class="stat-num white">@ViewBag.TotalSlots</div>
            <div class="stat-label">Total Slots</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-num green">@ViewBag.Available</div>
            <div class="stat-label">Available</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🚗</div>
            <div class="stat-num red">@ViewBag.Occupied</div>
            <div class="stat-label">Occupied</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📅</div>
            <div class="stat-num amber">@ViewBag.Reserved</div>
            <div class="stat-label">Reserved</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📋</div>
            <div class="stat-num white">@ViewBag.TotalBookings</div>
            <div class="stat-label">Total Bookings</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🟢</div>
            <div class="stat-num green">@ViewBag.ActiveBookings</div>
            <div class="stat-label">Active Bookings</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <div class="stat-num blue">@ViewBag.TotalUsers</div>
            <div class="stat-label">Total Users</div>
        </div>
    </div>

    <div class="section-title">Slots Status</div>
    <div class="slots-grid">
        @foreach (var slot in ViewBag.Slots ?? new List<SmartParking.Models.Slot>())
        {
            <div class="slot-pill @slot.Status.ToLower()">@slot.SlotNumber — @slot.Status</div>
        }
    </div>

    <div class="table-wrapper">
        <div class="table-header">
            <h3>All Bookings</h3>
        </div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Slot</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.BookingId</td>
                        <td>@b.User?.FullName</td>
                        <td>@b.Slot?.SlotNumber</td>
                        <td>@b.StartTime.ToString("dd MMM, HH:mm")</td>
                        <td>@b.EndTime.ToString("dd MMM, HH:mm")</td>
                        <td><span class="badge @b.Status.ToLower()">@b.Status</span></td>
                        <td>
                            @if (b.Status == "Active")
                            {
                                <form method="post" asp-action="CancelBooking" asp-controller="Admin" style="display:inline">
                                    <input type="hidden" name="bookingId" value="@b.BookingId" />
                                    <button type="submit" class="action-btn cancel">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

</body>
</html>