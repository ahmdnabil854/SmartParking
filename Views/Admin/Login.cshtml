@{
    ViewData["Title"] = "Admin Login";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
    body { font-family: 'Inter', sans-serif; background: #0f0f1a; }
    .auth-wrapper { max-width: 400px; margin: 80px auto; background: #1a1a2e; border-radius: 20px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .auth-header { padding: 32px 24px; text-align: center; border-bottom: 1px solid #2a2a3e; }
    .auth-header .icon { font-size: 36px; margin-bottom: 12px; }
    .auth-header h1 { color: #e8f5a3; font-size: 20px; font-weight: 600; margin: 0; }
    .auth-header p { color: #9FE1CB; font-size: 13px; margin-top: 6px; }
    .auth-body { padding: 28px 24px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { font-size: 12px; font-weight: 600; color: #9FE1CB; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 6px; }
    .form-group input { width: 100%; padding: 12px 14px; background: #0f0f1a; border: 1.5px solid #2a2a3e; border-radius: 10px; font-size: 14px; font-family: 'Inter', sans-serif; color: #fff; outline: none; transition: border 0.2s; }
    .form-group input:focus { border-color: #1D9E75; }
    .error-box { background: rgba(216,90,48,0.15); border: 1.5px solid #D85A30; border-radius: 10px; padding: 10px 14px; font-size: 13px; color: #D85A30; margin-bottom: 16px; }
    .submit-btn { width: 100%; background: #e8f5a3; color: #1a1a2e; border: none; padding: 14px; border-radius: 12px; font-size: 15px; font-weight: 700; cursor: pointer; transition: background 0.2s; }
    .submit-btn:hover { background: #d4e88a; }
</style>

<div class="auth-wrapper">
    <div class="auth-header">
        <div class="icon">🔐</div>
        <h1>Admin Panel</h1>
        <p>SmartParking Management</p>
    </div>
    <div class="auth-body">
        @if (ViewBag.Error != null)
        {
            <div class="error-box">@ViewBag.Error</div>
        }
        <form method="post" asp-action="Login" asp-controller="Admin">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="admin" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>
            <button type="submit" class="submit-btn">Login to Dashboard</button>
        </form>
    </div>
</div>