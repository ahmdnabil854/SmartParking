@model IEnumerable<SmartParking.Models.Slot>

@{
    ViewData["Title"] = "Smart Parking";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
    body { font-family: 'Inter', sans-serif; background: #f5f3ee; }
    .parking-wrapper { max-width: 800px; margin: 30px auto; background: #fff; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    .parking-header { background: #1a1a2e; padding: 20px 24px; display: flex; align-items: center; gap: 12px; }
    .parking-header h1 { color: #fff; font-size: 18px; font-weight: 500; margin: 0; }
    .parking-header span { background: #e8f5a3; color: #1a1a2e; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 20px; margin-left: auto; }
    .parking-body { padding: 24px; }
    .section-title { font-size: 12px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .slots-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-bottom: 28px; }
    .slot-card { border-radius: 12px; padding: 14px 10px; text-align: center; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; }
    .slot-card.available { background: #f0faf5; border-color: #1D9E75; }
    .slot-card.occupied { background: #fff0ee; border-color: #D85A30; cursor: not-allowed; }
    .slot-card.reserved { background: #fffbf0; border-color: #BA7517; cursor: not-allowed; }
    .slot-card.selected { background: #e8f5a3 !important; border-color: #1a1a2e !important; }
    .slot-card svg { width: 32px; height: 32px; margin-bottom: 6px; }
    .slot-num { font-size: 13px; font-weight: 600; color: #1a1a2e; }
    .slot-status { font-size: 10px; margin-top: 2px; }
    .slot-status.available { color: #1D9E75; }
    .slot-status.occupied { color: #D85A30; }
    .slot-status.reserved { color: #BA7517; }
    .booking-type-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 24px; }
    .type-btn { padding: 14px 10px; border-radius: 12px; border: 2px solid #e5e5e5; background: #fff; cursor: pointer; text-align: center; transition: all 0.2s; }
    .type-btn:hover { border-color: #1D9E75; }
    .type-btn.selected { background: #e8f5a3; border-color: #1a1a2e; }
    .type-btn .type-icon { font-size: 22px; margin-bottom: 4px; }
    .type-btn .type-label { font-size: 13px; font-weight: 600; color: #1a1a2e; }
    .type-btn .type-price { font-size: 11px; color: #888; margin-top: 2px; }
    .date-section { margin-bottom: 24px; }
    .date-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .date-group label { font-size: 12px; color: #888; display: block; margin-bottom: 6px; }
    .date-group input { width: 100%; padding: 10px 12px; border: 1.5px solid #e5e5e5; border-radius: 10px; font-size: 13px; font-family: 'Inter', sans-serif; color: #1a1a2e; outline: none; transition: border 0.2s; }
    .date-group input:focus { border-color: #1D9E75; }
    .hour-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; margin-top: 16px; }
    .time-btn { padding: 8px 4px; border-radius: 10px; border: 1.5px solid #e5e5e5; background: #fff; font-size: 12px; font-weight: 500; color: #555; cursor: pointer; text-align: center; transition: all 0.2s; }
    .time-btn:hover { border-color: #1D9E75; color: #1D9E75; }
    .time-btn.selected { background: #e8f5a3; border-color: #1a1a2e; color: #1a1a2e; font-weight: 600; }
    .hour-counter { display: flex; align-items: center; gap: 16px; margin-top: 16px; }
    .counter-btn { width: 36px; height: 36px; border-radius: 50%; border: 1.5px solid #e5e5e5; background: #fff; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .counter-btn:hover { border-color: #1D9E75; color: #1D9E75; }
    .counter-val { font-size: 18px; font-weight: 600; color: #1a1a2e; min-width: 30px; text-align: center; }
    .counter-label { font-size: 13px; color: #888; }
    .month-quick { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; }
    .month-btn { padding: 10px 8px; border-radius: 10px; border: 1.5px solid #e5e5e5; background: #fff; font-size: 12px; font-weight: 500; color: #555; cursor: pointer; text-align: center; transition: all 0.2s; }
    .month-btn:hover { border-color: #1D9E75; color: #1D9E75; }
    .month-btn.selected { background: #e8f5a3; border-color: #1a1a2e; color: #1a1a2e; font-weight: 600; }
    .summary-box { background: #f9f9f6; border-radius: 12px; padding: 16px; margin-bottom: 24px; border: 1.5px solid #e5e5e5; }
    .summary-row { display: flex; justify-content: space-between; font-size: 13px; color: #555; margin-bottom: 8px; }
    .summary-row:last-child { margin-bottom: 0; font-weight: 600; color: #1a1a2e; font-size: 15px; }
    .booking-footer { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; background: #f9f9f9; border-top: 1px solid #f0f0f0; }
    .total-price { font-size: 24px; font-weight: 600; color: #1a1a2e; }
    .total-label { font-size: 12px; color: #888; }
    .book-btn { background: #1a1a2e; color: #e8f5a3; border: none; padding: 14px 32px; border-radius: 12px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .book-btn:hover { background: #0F6E56; }
    .book-btn:disabled { background: #ccc; cursor: not-allowed; color: #fff; }
</style>

<div class="parking-wrapper">
    <div class="parking-header">
        <svg width="24" height="24" fill="none" stroke="#e8f5a3" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>
        </svg>
        <h1>Smart Parking</h1>
        <span>@Model.Count(s => s.Status == "Available") Available</span>
    </div>

    <div class="parking-body">

        <div class="section-title">Choose a parking spot</div>
        <div class="slots-grid">
            @foreach (var slot in Model)
            {
                <div class="slot-card @slot.Status.ToLower()" id="slot-@slot.SlotId"
                     onclick="selectSlot(@slot.SlotId, '@slot.Status', '@slot.SlotNumber')">
                    @if (slot.Status == "Available")
                    {
                        <svg viewBox="0 0 48 48" fill="none">
                            <rect width="48" height="48" rx="8" fill="#e8f5e9"/>
                            <path d="M10 34l4-12h20l4 12H10z" fill="#1D9E75"/>
                            <rect x="8" y="33" width="32" height="5" rx="2" fill="#0F6E56"/>
                            <circle cx="16" cy="36" r="3" fill="#fff"/>
                            <circle cx="32" cy="36" r="3" fill="#fff"/>
                        </svg>
                    }
                    else if (slot.Status == "Occupied")
                    {
                        <svg viewBox="0 0 48 48" fill="none">
                            <rect width="48" height="48" rx="8" fill="#fdecea"/>
                            <path d="M10 34l4-12h20l4 12H10z" fill="#D85A30"/>
                            <rect x="8" y="33" width="32" height="5" rx="2" fill="#993C1D"/>
                            <circle cx="16" cy="36" r="3" fill="#fff"/>
                            <circle cx="32" cy="36" r="3" fill="#fff"/>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 48 48" fill="none">
                            <rect width="48" height="48" rx="8" fill="#fffde7"/>
                            <path d="M10 34l4-12h20l4 12H10z" fill="#BA7517"/>
                            <rect x="8" y="33" width="32" height="5" rx="2" fill="#854F0B"/>
                            <circle cx="16" cy="36" r="3" fill="#fff"/>
                            <circle cx="32" cy="36" r="3" fill="#fff"/>
                        </svg>
                    }
                    <div class="slot-num">@slot.SlotNumber</div>
                    <div class="slot-status @slot.Status.ToLower()">@slot.Status</div>
                </div>
            }
        </div>

        <div class="section-title">Booking type</div>
        <div class="booking-type-grid">
            <div class="type-btn" id="type-hour" onclick="selectType('hour')">
                <div class="type-icon">⏱</div>
                <div class="type-label">By Hour</div>
                <div class="type-price">10 EGP / hr</div>
            </div>
            <div class="type-btn" id="type-day" onclick="selectType('day')">
                <div class="type-icon">📅</div>
                <div class="type-label">By Day</div>
                <div class="type-price">100 EGP / day</div>
            </div>
            <div class="type-btn" id="type-month" onclick="selectType('month')">
                <div class="type-icon">🗓</div>
                <div class="type-label">By Month</div>
                <div class="type-price">1500 EGP / month</div>
            </div>
        </div>

        <div class="date-section" id="date-section" style="display:none">
            <div class="section-title" id="date-label">Select date</div>

            <!-- Hour mode -->
            <div id="hour-mode" style="display:none">
                <div class="date-grid">
                    <div class="date-group">
                        <label>Date</label>
                        <input type="date" id="hour-date" onchange="updateHour()" />
                    </div>
                </div>
                <div class="section-title" style="margin-top:16px">Start hour</div>
                <div class="hour-grid">
                    @foreach (var h in new[]{"08:00","09:00","10:00","11:00","12:00","13:00","14:00","15:00","16:00","17:00","18:00","19:00","20:00","21:00"})
                    {
                        <div class="time-btn" onclick="selectHour('@h', event)">@h</div>
                    }
                </div>
                <div class="section-title" style="margin-top:16px">Number of hours</div>
                <div class="hour-counter">
                    <div class="counter-btn" onclick="changeHours(-1)">−</div>
                    <div class="counter-val" id="hour-count">1</div>
                    <div class="counter-label">hour(s)</div>
                    <div class="counter-btn" onclick="changeHours(1)">+</div>
                </div>
            </div>

            <!-- Day mode -->
            <div id="day-mode" style="display:none">
                <div class="date-grid">
                    <div class="date-group">
                        <label>From</label>
                        <input type="date" id="day-start" onchange="calcDayPrice()" />
                    </div>
                    <div class="date-group">
                        <label>To</label>
                        <input type="date" id="day-end" onchange="calcDayPrice()" />
                    </div>
                </div>
            </div>

            <!-- Month mode -->
            <div id="month-mode" style="display:none">
                <div class="month-quick" id="month-grid"></div>
            </div>
        </div>

        <div class="summary-box" id="summary-box" style="display:none">
            <div class="summary-row"><span>Spot</span><span id="sum-spot">—</span></div>
            <div class="summary-row"><span>From</span><span id="sum-from">—</span></div>
            <div class="summary-row"><span>To</span><span id="sum-to">—</span></div>
            <div class="summary-row"><span>Duration</span><span id="sum-duration">—</span></div>
            <div class="summary-row"><span>Total Price</span><span id="sum-price">—</span></div>
        </div>

    </div>

    <div class="booking-footer">
        <div>
            <div class="total-label">Total Price</div>
            <div class="total-price" id="total-price">0 EGP</div>
        </div>
        <form asp-action="Book" asp-controller="Parking" method="post" id="booking-form">
            <input type="hidden" name="slotId" id="selected-slot-id" value="0" />
            <input type="hidden" name="startTime" id="selected-start-time" value="" />
            <input type="hidden" name="endTime" id="selected-end-time" value="" />
            <button type="submit" class="book-btn" id="book-btn" disabled>Book Place</button>
        </form>
    </div>
</div>

<script>
    let selectedSlot = null;
    let selectedSlotNum = '';
    let selectedType = null;
    let selectedHourVal = null;
    let hourCount = 1;
    const PRICE_HOUR = 10;
    const PRICE_DAY = 100;
    const PRICE_MONTH = 1500;

    function selectSlot(id, status, num) {
        if (status !== 'Available') return;
        document.querySelectorAll('.slot-card').forEach(c => c.classList.remove('selected'));
        document.getElementById('slot-' + id).classList.add('selected');
        selectedSlot = id;
        selectedSlotNum = num;
        document.getElementById('selected-slot-id').value = id;
        document.getElementById('sum-spot').textContent = num;
        checkReady();
    }

    function selectType(type) {
        selectedType = type;
        selectedHourVal = null;
        hourCount = 1;
        document.getElementById('hour-count').textContent = '1';
        document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
        document.getElementById('type-' + type).classList.add('selected');
        document.getElementById('date-section').style.display = 'block';
        document.getElementById('hour-mode').style.display = 'none';
        document.getElementById('day-mode').style.display = 'none';
        document.getElementById('month-mode').style.display = 'none';
        document.getElementById('summary-box').style.display = 'none';
        document.getElementById('total-price').textContent = '0 EGP';

        if (type === 'hour') {
            document.getElementById('date-label').textContent = 'Select date & time';
            document.getElementById('hour-mode').style.display = 'block';
        } else if (type === 'day') {
            document.getElementById('date-label').textContent = 'Select days';
            document.getElementById('day-mode').style.display = 'block';
        } else if (type === 'month') {
            document.getElementById('date-label').textContent = 'Select month';
            document.getElementById('month-mode').style.display = 'block';
            buildMonthGrid();
        }
        checkReady();
    }

    function selectHour(h, e) {
        document.querySelectorAll('.time-btn').forEach(b => b.classList.remove('selected'));
        e.target.classList.add('selected');
        selectedHourVal = h;
        updateHour();
    }

    function changeHours(delta) {
        hourCount = Math.max(1, Math.min(12, hourCount + delta));
        document.getElementById('hour-count').textContent = hourCount;
        updateHour();
    }

    function updateHour() {
        const dateVal = document.getElementById('hour-date').value;
        if (!dateVal || !selectedHourVal) return;
        const start = new Date(dateVal + 'T' + selectedHourVal + ':00');
        const end = new Date(start.getTime() + hourCount * 3600000);
        document.getElementById('selected-start-time').value = formatDate(start);
        document.getElementById('selected-end-time').value = formatDate(end);
        const price = hourCount * PRICE_HOUR;
        showSummary(start, end, hourCount + ' hour(s)', price);
        checkReady();
    }

    function calcDayPrice() {
        const s = document.getElementById('day-start').value;
        const e = document.getElementById('day-end').value;
        if (!s || !e) return;
        const start = new Date(s + 'T00:00:00');
        const end = new Date(e + 'T23:59:59');
        if (end < start) return;
        const days = Math.ceil((end - start) / 86400000);
        const price = days * PRICE_DAY;
        document.getElementById('selected-start-time').value = formatDate(start);
        document.getElementById('selected-end-time').value = formatDate(end);
        showSummary(start, end, days + ' day(s)', price);
        checkReady();
    }

    function buildMonthGrid() {
        const grid = document.getElementById('month-grid');
        grid.innerHTML = '';
        const now = new Date();
        for (let i = 0; i < 8; i++) {
            const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
            const label = d.toLocaleString('en', { month: 'long', year: 'numeric' });
            const btn = document.createElement('div');
            btn.className = 'month-btn';
            btn.textContent = label;
            btn.onclick = () => selectMonth(d, btn);
            grid.appendChild(btn);
        }
    }

    function selectMonth(date, btn) {
        document.querySelectorAll('.month-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        const start = new Date(date.getFullYear(), date.getMonth(), 1, 0, 0, 0);
        const end = new Date(date.getFullYear(), date.getMonth() + 1, 0, 23, 59, 59);
        document.getElementById('selected-start-time').value = formatDate(start);
        document.getElementById('selected-end-time').value = formatDate(end);
        showSummary(start, end, '1 month', PRICE_MONTH);
        checkReady();
    }

    function showSummary(start, end, duration, price) {
        document.getElementById('sum-from').textContent = start.toLocaleString('en-EG');
        document.getElementById('sum-to').textContent = end.toLocaleString('en-EG');
        document.getElementById('sum-duration').textContent = duration;
        document.getElementById('sum-price').textContent = price.toLocaleString() + ' EGP';
        document.getElementById('total-price').textContent = price.toLocaleString() + ' EGP';
        document.getElementById('summary-box').style.display = 'block';
    }

    function formatDate(d) {
        return d.getFullYear() + '-' +
            String(d.getMonth() + 1).padStart(2, '0') + '-' +
            String(d.getDate()).padStart(2, '0') + 'T' +
            String(d.getHours()).padStart(2, '0') + ':' +
            String(d.getMinutes()).padStart(2, '0') + ':00';
    }

    function checkReady() {
        const start = document.getElementById('selected-start-time').value;
        const end = document.getElementById('selected-end-time').value;
        document.getElementById('book-btn').disabled = !(selectedSlot && start && end);
    }
</script>